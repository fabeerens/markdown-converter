# Optioneel: nodig voor "Opschonen met AI".
# Kopieer dit bestand naar .env en vul je OpenRouter API-sleutel in.
#
#   cp .env.example .env
#
# Sleutel aanmaken op https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

